# ── API Keys ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here
CBORG_API_KEY=your-cborg-key-here
MP_API_KEY=your-materials-project-key-here

# ── CBORG (LBL LLM gateway) ────────────────────────────────────────────────────
CBORG_BASE_URL=https://api.cborg.lbl.gov

# ── Ollama ─────────────────────────────────────────────────────────────────────
KG_RAG_OLLAMA_URL=http://localhost:11434/api/chat
KG_RAG_OLLAMA_MODEL=qwen3:8b

# ── Agent (app/agent.py) ───────────────────────────────────────────────────────
AGENT_CLAUDE_MODEL=qwen3.5:9b

# ── Knowledge graph ────────────────────────────────────────────────────────────
KG_RAG_GRAPH=storage/kg/matkg_qwen3_235b_580papers.json
KG_RAG_PDF_DIR=polymer_papers

# ── Retrieval tuning ───────────────────────────────────────────────────────────
KG_RAG_TOPK=12
KG_RAG_EMBED_MODEL=all-MiniLM-L6-v2
KG_RAG_ENABLE_BFS=1
KG_RAG_BFS_TOPK=24
KG_RAG_MAX_HOPS=1
KG_RAG_STEPWISE=1
KG_RAG_STEPWISE_MAX_STEPS=6
KG_RAG_GENERIC_PENALTY=0.8
KG_RAG_CONTEXT_VOLUME=150
KG_RAG_STRUCT_CTX=1

# ── Context / snippet limits ───────────────────────────────────────────────────
KG_RAG_CTX_CHARS=16000
KG_RAG_SNIP=1000

# ── Performance ────────────────────────────────────────────────────────────────
KG_RAG_FORCE_CPU=
KG_RAG_BATCH=
KG_RAG_MAX_TEXT_CHARS=1024
KG_RAG_PDF_CACHE=256

# ── Debug ──────────────────────────────────────────────────────────────────────
KG_RAG_DEBUG=0
